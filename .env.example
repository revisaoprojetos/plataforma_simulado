# =====================================================================
# Variáveis de ambiente — plataforma_simulado
# Copie para `.env` e preencha com valores reais. NUNCA commite o `.env`.
# Deploy em produção: ver docs/deploy/runbook-vps.md
# =====================================================================

NODE_ENV=development

# --- Supabase (Postgres/Auth/Storage gerenciado) --------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres direto p/ hotspots de relatório (Fase 1). Sem isto, tudo segue em PostgREST. --
# Connection string do POOLER do Supabase (Settings → Database → Connection string →
# "Transaction"/"Session pooler"), com a senha do banco. Ex.:
#   postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL=
DATABASE_POOL_MAX=5
# REPORT_SQL: vazio/'on' = usa SQL direto quando DATABASE_URL existir; 'shadow' = roda os dois
# e loga divergências mas serve o PostgREST (validação segura); 'off' = desliga o SQL direto.
REPORT_SQL=

# --- Cache de relatórios (Redis, Fase 0). Vazio = ligado; 'off' = desliga. TTL em segundos. --
RELATORIO_CACHE=
RELATORIO_CACHE_TTL=600

# --- Fila / PDF (Redis + Gotenberg, consumidos pelo worker) ---------------
REDIS_URL=redis://localhost:6379
GOTENBERG_URL=http://localhost:3001
WEB_INTERNAL_URL=http://localhost:3000
PDF_RENDER_SECRET=
PDF_PUBLIC_BASE=

# --- Segredos internos da app -----------------------------------------------
CRON_SECRET=
APP_ENCRYPTION_KEY=
ALUNO_SESSION_SECRET=

# --- Curseduca (integração externa) ------------------------------------------
CURSEDUCA_API_KEY=
CURSEDUCA_BASE_URL=https://prof.curseduca.pro
CURSEDUCA_USER=
CURSEDUCA_PASS=
CURSEDUCA_WEBHOOK_SECRET=
CURSEDUCA_ENV_TENANT_ID=

# --- App pública / multi-tenant -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo

# --- Storage (default 'supabase', já funcional). Não usado neste deploy. ------
STORAGE_PROVIDER=supabase
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
